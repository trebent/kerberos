{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://trebent.com/kerberos/schemas/persistence_schema.json",
  "type": "object",
  "properties": {
    "driver": {
      "type": "string",
      "enum": ["sqlite", "postgres"],
      "description": "The backing database driver to use."
    },
    "address": {
      "type": "string",
      "minLength": 1,
      "description": "Database address. For postgres: host:port. For sqlite: file path."
    },
    "database": {
      "type": "string",
      "minLength": 1,
      "description": "Database name (postgres only)."
    },
    "username": {
      "type": "string",
      "description": "Database user (postgres only)."
    },
    "password": {
      "type": "string",
      "description": "Database password (postgres only)."
    },
    "sslMode": {
      "type": "string",
      "description": "SSL mode for postgres connections (e.g. disable, require, verify-full)."
    }
  },
  "required": ["driver"],
  "additionalProperties": false
}
