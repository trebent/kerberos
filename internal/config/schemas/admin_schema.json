{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://trebent.com/kerberos/schemas/admin_schema.json",
  "type": "object",
  "properties": {
    "api": {
      "type": "object",
      "properties": {
        "tls": {
          "type": "object",
          "properties": {
            "serverCertificate": {
              "type": "string"
            }
          },
          "required": [
            "serverCertificate"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "superUser": {
      "type": "object",
      "default": {},
      "properties": {
        "clientId": {
          "type": "string",
          "default": "admin"
        },
        "clientSecret": {
          "type": "string",
          "default": "secret"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}