{
  "gateway": {
    "router": {
      "backends": [
        {
          "name": "echo",
          "host": "echo",
          "port": 15000
        },
        {
          "name": "protected-echo",
          "host": "protected-echo",
          "port": 15000
        }
      ]
    }
  },
  "auth": {
    "methods": {
      "basic": {}
    },
    "scheme": {
      "mappings": [
        {
          "backend": "${ref:gateway.router.backends[1].name}",
          "method": "basic",
          "exempt": [
            "/unprotected",
            "/unprotected/*"
          ],
          "authorization": {
            "groups": [
              "staff"
            ],
            "paths": {
              "/long/hello": [
                "pleb"
              ]
            }
          }
        }
      ]
    },
    "order": 1
  },
  "oas": {
    "mappings": [
      {
        "backend": "${ref:gateway.router.backends[0].name}",
        "specification": "/oas/echo.yaml"
      },
      {
        "backend": "${ref:gateway.router.backends[1].name}",
        "specification": "/oas/echo-protected.yaml"
      }
    ],
    "order": 100
  }
}