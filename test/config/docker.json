{
  "gateway": {
    "router": {
      "backends": [
        {
          "name": "echo",
          "host": "localhost",
          "port": 15000
        }
      ]
    }
  },
  "oas": {
    "mappings": [
      {
        "backend": "${ref:gateway.router.backends[0].name}",
        "specification": "/oas/echo.yaml"
      }
    ],
    "order": 100
  }
}